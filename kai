#!/bin/bash
# Kai — Your AI Shopify expert, product manager, and development team
# https://github.com/kraftapps-ai/kai
#
# Just run: kai

set -e

# ── Version ───────────────────────────────────────────

KAI_VERSION=$(node -p "require('$(dirname "$(readlink -f "$(which kai)" 2>/dev/null || echo "$0")")/package.json').version" 2>/dev/null || echo "unknown")

if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
    echo "kai v${KAI_VERSION}"
    exit 0
fi

PRD_FILE=".kai/stories.json"
PROGRESS_FILE=".kai/progress.txt"
PROMPT_FILE=".kai/PROMPT.md"
MEMORY_FILE=".kai/memory.md"
SESSION_FILE=".kai/session_id"
LOOP_SCRIPT=".kai/loop.sh"

# ── Handle --new flag ─────────────────────────────────

if [ "${1:-}" = "--new" ]; then
    rm -f "$SESSION_FILE"
    shift
fi

# ── Ensure .kai/ is git-ignored ───────────────────────

mkdir -p .kai
if [ ! -f ".kai/.gitignore" ]; then
    echo "*" > .kai/.gitignore
fi

# ── Auto-init if needed ───────────────────────────────

# Migrate old file locations (pre-1.5.0)
if [ -f "kai.json" ] && [ ! -f "$PRD_FILE" ]; then
    mkdir -p .kai
    mv kai.json "$PRD_FILE"
    echo "  Migrated kai.json → $PRD_FILE"
fi
if [ -f "kai-progress.txt" ] && [ ! -f "$PROGRESS_FILE" ]; then
    mkdir -p .kai
    mv kai-progress.txt "$PROGRESS_FILE"
    echo "  Migrated kai-progress.txt → $PROGRESS_FILE"
fi

if [ ! -f "$PRD_FILE" ]; then
    mkdir -p .kai

    cat > "$PRD_FILE" << 'EOF'
{
  "branchName": "main",
  "userStories": []
}
EOF

    echo "# Kai Progress Log" > "$PROGRESS_FILE"

    cat > "$PROMPT_FILE" << 'EOF'
# Project Context

Add your project-specific context here. The more you provide, the better Kai performs.

## Shopify Store
<!-- Kai auto-detects store info from shopify.app.toml and .env -->
<!-- Only fill this in if auto-detection doesn't work for your setup -->
<!-- Store domain: your-store.myshopify.com -->
<!-- App handle: your-app-handle -->

## Tech stack
<!-- e.g., Remix + TypeScript, Next.js, Ruby on Rails -->

## Build command
<!-- e.g., npm run build, shopify app build -->

## Test command
<!-- e.g., npm test, shopify app test -->

## Dev command
<!-- e.g., npm run dev, shopify app dev -->

## Project structure
<!-- Key directories and files -->

## Conventions
<!-- Coding style, naming, patterns -->
EOF
fi

# Init memory file if it doesn't exist
if [ ! -f "$MEMORY_FILE" ]; then
    mkdir -p .kai
    cat > "$MEMORY_FILE" << 'EOF'
# Kai Memory

This file is automatically maintained by Kai to preserve context between sessions.
Do not edit manually unless you want to correct or add context for Kai.

## Current Focus
<!-- What we're currently working on -->

## Key Decisions
<!-- Important decisions made during our conversations -->

## Open Questions / Blockers
<!-- Things that need to be resolved -->

## Session Log
<!-- Brief log of what happened in each session -->
EOF
fi

# ── Ensure MCP servers are available ─────────────────

# Track what's already configured
playwright_available=false
shopify_dev_available=false
mantle_available=false

for config in \
    ".mcp.json" \
    ".claude/settings.local.json" \
    "$HOME/.claude/settings.local.json" \
    "$HOME/.claude/settings.json"; do
    if [ -f "$config" ]; then
        grep -q "playwright" "$config" 2>/dev/null && playwright_available=true
        grep -q "shopify-dev" "$config" 2>/dev/null && shopify_dev_available=true
        grep -q "mantle" "$config" 2>/dev/null && mantle_available=true
    fi
done

# Check Claude Code plugins for Playwright
if [ "$playwright_available" = false ]; then
    for plugin_dir in "$HOME/.claude/plugins"/*/external_plugins/playwright/; do
        if [ -f "${plugin_dir}.mcp.json" ]; then
            playwright_available=true
            break
        fi
    done
fi

# Build MCP config with all needed servers
needs_mcp_update=false
if [ "$playwright_available" = false ] || [ "$shopify_dev_available" = false ] || [ "$mantle_available" = false ]; then
    needs_mcp_update=true
fi

if [ "$needs_mcp_update" = true ]; then
    if [ -f ".mcp.json" ]; then
        # Merge with existing config
        mcp_config=$(cat .mcp.json)

        if [ "$playwright_available" = false ] && ! echo "$mcp_config" | grep -q "playwright"; then
            echo "Setting up Playwright browser testing..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers.playwright = {"command": "npx", "args": ["@playwright/mcp@latest"]}')
        fi

        if [ "$shopify_dev_available" = false ] && ! echo "$mcp_config" | grep -q "shopify-dev"; then
            echo "Setting up Shopify Dev MCP (docs, GraphQL schemas, Liquid validation)..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["shopify-dev-mcp"] = {"command": "npx", "args": ["-y", "@shopify/dev-mcp@latest"]}')
        fi

        if [ "$mantle_available" = false ] && ! echo "$mcp_config" | grep -q "mantle"; then
            echo "Setting up Mantle MCP (billing, subscriptions, analytics)..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["mantle-foundations"] = {"url": "https://mcp.heymantle.com/foundations"}')
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["mantle-core"] = {"url": "https://mcp.heymantle.com/core"}')
        fi

        echo "$mcp_config" > .mcp.json
    else
        echo "Setting up MCP servers..."
        echo "  - Playwright (browser testing)"
        echo "  - Shopify Dev MCP (docs, GraphQL schemas, Liquid validation)"
        echo "  - Mantle MCP (billing, subscriptions, analytics)"

        cat > .mcp.json << 'MCPEOF'
{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "shopify-dev-mcp": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"]
    },
    "mantle-foundations": {
      "url": "https://mcp.heymantle.com/foundations"
    },
    "mantle-core": {
      "url": "https://mcp.heymantle.com/core"
    }
  }
}
MCPEOF
    fi
    echo "  MCP servers configured in .mcp.json"
fi

# ── Create the implementation loop script ─────────────

cat > "$LOOP_SCRIPT" << 'LOOPEOF'
#!/bin/bash
# Kai implementation loop — called by the PM when stories are ready
set -e

PRD_FILE=".kai/stories.json"
PROGRESS_FILE=".kai/progress.txt"
PROMPT_FILE=".kai/PROMPT.md"

WORKER_PROMPT='You are an autonomous Shopify expert AI developer.

## Shopify MCP tools — USE THEM
- learn_shopify_api → call FIRST before any Shopify work
- introspect_graphql_schema → find exact types, fields, mutations
- search_docs_chunks / fetch_full_docs → implementation guidance
- validate_graphql_codeblocks → validate GraphQL BEFORE committing
- validate_theme_codeblocks / validate_theme → validate Liquid

Workflow: learn_shopify_api → introspect schema → implement → validate. NEVER guess API fields.

## Inputs
- @.kai/stories.json — stories with passes: true/false
- @.kai/progress.txt — previous work log

## Task (ONE story per loop)
1. Find highest-priority story with passes: false
2. Read progress for context
3. PLAN before coding — list files and changes
4. For Shopify APIs: introspect schema + search docs first
5. Implement ONLY that story
6. Validate: build/tests + validate_graphql_codeblocks + validate_theme_codeblocks
7. SELF-REVIEW: cite evidence per criterion (file, line, output). No "should work".
8. Commit, set passes: true, append to progress

## Rules
- ONE STORY. No placeholders. Fully implement or BLOCKED.
- Do not break existing functionality.
- Validate GraphQL/Liquid with MCP tools before marking complete.
- All stories done → output: <promise>COMPLETE</promise>

## Anti-rationalization
- "Already done" → verify first. "Mark complete" → no code = not done.
- "Build passes" → build ≠ correct. "Close enough" → partial = broken.
- "Skip review" → always review. "I know the API" → introspect first.'

context_files="@${PROMPT_FILE} @${PRD_FILE} @${PROGRESS_FILE}"
if [ -f ".kai/context.txt" ]; then
    while IFS= read -r file; do
        [ -n "$file" ] && [ -f "$file" ] && context_files="$context_files @${file}"
    done < .kai/context.txt
fi

iteration=0
review_failures=0

while :; do
    iteration=$((iteration + 1))
    REMAINING=$(jq '[.userStories[] | select(.passes == false)] | length' "$PRD_FILE")

    if [ "$REMAINING" -eq 0 ]; then
        echo "All stories complete!"
        break
    fi

    NEXT_ID=$(jq -r '[.userStories[] | select(.passes == false)] | sort_by(.priority) | .[0].id' "$PRD_FILE")
    NEXT=$(jq -r '[.userStories[] | select(.passes == false)] | sort_by(.priority) | .[0].title' "$PRD_FILE")

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "#${iteration} — $(date)"
    echo "  Remaining: $REMAINING | Next: $NEXT"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    start_time=$(date +%s)

    set +e
    result=$(claude -p --dangerously-skip-permissions $context_files)
    exit_code=$?
    set -e

    elapsed=$(( $(date +%s) - start_time ))
    echo "$result" | tail -20

    if [ $exit_code -ne 0 ]; then
        echo "Failed (code ${exit_code}). Restarting..."
        continue
    fi

    if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
        echo "All stories complete after $iteration iterations!"
        exit 0
    fi

    # Review
    STORY_PASSES=$(jq -r ".userStories[] | select(.id == $NEXT_ID) | .passes" "$PRD_FILE")
    if [ "$STORY_PASSES" = "true" ]; then
        last_commit=$(git log --oneline -1 2>/dev/null || echo "no git")
        ACCEPTANCE=$(jq -r ".userStories[] | select(.id == $NEXT_ID) | .acceptanceCriteria | join(\"\n- \")" "$PRD_FILE")

        set +e
        review=$(claude -p --dangerously-skip-permissions \
          "You are a Shopify expert code reviewer. Story #${NEXT_ID} ('${NEXT}') claims complete.
Last commit: ${last_commit}
Acceptance criteria:
- ${ACCEPTANCE}
Read git diff HEAD~1 HEAD. Verify EACH criterion. Be skeptical.
If the story involves Shopify APIs, use introspect_graphql_schema to verify the code uses correct fields and types.
If it involves Liquid, use validate_theme_codeblocks to check for errors.
If ANY fails: REVIEW_FAIL: [reason]
If all pass: REVIEW_PASS")
        set -e

        echo "$review" | tail -5

        if [[ "$review" == *"REVIEW_FAIL"* ]]; then
            jq --argjson id "$NEXT_ID" '(.userStories[] | select(.id == $id)).passes = false' "$PRD_FILE" > "${PRD_FILE}.tmp" && mv "${PRD_FILE}.tmp" "$PRD_FILE"
            echo "REVIEW FEEDBACK: $review" >> "$PROGRESS_FILE"
            review_failures=$((review_failures + 1))
            [ $review_failures -ge 3 ] && {
                jq --argjson id "$NEXT_ID" '(.userStories[] | select(.id == $id)).passes = true' "$PRD_FILE" > "${PRD_FILE}.tmp" && mv "${PRD_FILE}.tmp" "$PRD_FILE"
                review_failures=0
            }
        else
            review_failures=0
        fi
    fi

    echo "Done in $((elapsed / 60))m $((elapsed % 60))s"
    echo ""
done
LOOPEOF
chmod +x "$LOOP_SCRIPT"

# ── Build status summary ──────────────────────────────

status=""
if [ -f "$PRD_FILE" ]; then
    total=$(jq '.userStories | length' "$PRD_FILE")
    done_count=$(jq '[.userStories[] | select(.passes == true)] | length' "$PRD_FILE")
    remaining=$((total - done_count))
    if [ "$total" -gt 0 ]; then
        status="

Current progress: ${done_count}/${total} stories complete (${remaining} remaining).
$(jq -r '.userStories[] | "- [\(if .passes then "DONE" else "TODO" end)] #\(.id): \(.title)"' "$PRD_FILE")"
    fi
fi

project_context=""
if [ -f "$PROMPT_FILE" ]; then
    # Strip HTML comments to save tokens
    stripped=$(sed 's/<!--.*-->//g' "$PROMPT_FILE" | sed '/^$/N;/^\n$/d')
    # Only inject if there's real content beyond the template headers
    if echo "$stripped" | grep -qvE '^(#|$)'; then
        project_context="

Project context (.kai/PROMPT.md):
${stripped}"
    fi
fi

progress=""
if [ -f "$PROGRESS_FILE" ] && [ "$(wc -l < "$PROGRESS_FILE")" -gt 2 ]; then
    progress="

Recent progress:
$(tail -15 "$PROGRESS_FILE")"
fi

memory=""
if [ -f "$MEMORY_FILE" ]; then
    # Strip HTML comments and check for real content
    stripped_mem=$(sed 's/<!--.*-->//g' "$MEMORY_FILE" | sed '/^$/N;/^\n$/d')
    if echo "$stripped_mem" | grep -qvE '^(#|$)'; then
        memory="

## Kai Memory
${stripped_mem}"
    fi
fi

dev_name=$(git config user.name 2>/dev/null || echo "")
dev_greeting=""
[ -n "$dev_name" ] && dev_greeting="
The developer's name is: ${dev_name}"

# ── Build Claude args ─────────────────────────────────

CLAUDE_ARGS="--dangerously-skip-permissions"

# Session persistence: reuse the same session ID per repo
if [ -f "$SESSION_FILE" ]; then
    KAI_SESSION=$(cat "$SESSION_FILE")
else
    KAI_SESSION=$(uuidgen 2>/dev/null || python3 -c "import uuid; print(uuid.uuid4())" 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null)
    mkdir -p .kai
    echo "$KAI_SESSION" > "$SESSION_FILE"
fi
CLAUDE_ARGS="$CLAUDE_ARGS --name kai"

# ── Launch the PM ─────────────────────────────────────

SYSTEM_PROMPT="You are Kai — AI product manager, tech lead, and Shopify expert. You plan and ship Shopify apps, themes, and integrations.

## Memory (.kai/memory.md)

All context (stories, progress, memory) is pre-loaded below. On returning sessions: DO NOT read files on startup — greet instantly.

Update .kai/memory.md when: stories created/modified, dev loop completes, key decisions made, developer leaves. Sections: Current Focus, Key Decisions, Open Questions/Blockers, Session Log (dated, newest first, max 10).

## Shopify Dev MCP tools

USE THESE proactively — always prefer real schema over guessing:
- **learn_shopify_api** — init API context (call first)
- **search_docs_chunks** / **fetch_full_docs** — search/fetch shopify.dev docs
- **introspect_graphql_schema** — explore any Shopify GraphQL API schema (Admin, Storefront, Functions, Partner, etc.)
- **validate_graphql_codeblocks** — validate GraphQL against schema
- **validate_component_codeblocks** / **validate_theme_codeblocks** / **validate_theme** — validate components, Liquid files, full themes

## Storefront MCP

Per-store at \`https://{shop}.myshopify.com/api/mcp\`: search_shop_catalog, search_shop_policies_and_faqs, get_cart, update_cart.

## Mantle MCP

- **mantle-foundations** — billing integration code gen (plans, features, paywalls, usage tracking)
- **mantle-core** — customer analytics, subscriptions, revenue metrics, CRM

OAuth via browser on first use.

## Capabilities

1. **Brainstorm** — think through ideas, ground in Shopify docs/schema
2. **Create stories** — small (5-15 min), write to .kai/stories.json. Introspect schema first for API work.
3. **Run dev loop** — \`nohup .kai/loop.sh > .kai/loop.log 2>&1 &\`, monitor with \`tail -f .kai/loop.log\`
4. **Check progress** — read .kai/stories.json and .kai/progress.txt
5. **Adjust plan** — edit stories, reprioritize, add, reset
6. **Test in browser** — Playwright in Shopify Admin
7. **Research APIs** — introspect schemas, search docs

## Stories

Format: id, title, description, acceptanceCriteria, priority, passes (true/false) in .kai/stories.json.
Rules: independently committable, 5-15 min, verifiable criteria, last criterion = build/test passing, ordered by dependency.

## Browser testing (Playwright)

Tools: browser_navigate, browser_take_screenshot, browser_snapshot, browser_click, browser_run_code.
Use browser_snapshot for actions, browser_take_screenshot for visual verification.

**When developer says \"take a look\"/\"check\"/\"investigate\" a bug: use Playwright FIRST to see it yourself before touching code.**

### App URL construction

**NEVER guess. Store name ≠ app handle.**

Find from repo:
- \`shopify.app.toml\`: \`handle\` (app slug), \`[build] dev_store_url\` (store domain)
- \`.env\`: \`SHOP\` (store domain)

Build: \`https://admin.shopify.com/store/{STORE}/apps/{HANDLE}/{PAGE}\`
Extract STORE from domain (strip .myshopify.com).

**If dev_store_url and SHOP are both missing: ASK the developer. Never guess.**

## Personality

Direct, concise, hands-on Shopify expert. Make decisions, don't list options. On \"ship it\"/\"go\"/\"do it\" → start the loop. Introspect schema when unsure.

**Returning session:** greet by name, reference where you left off, no file reads, 2-3 lines max.
**Fresh start:** explore repo (package.json, shopify.app.toml, directory structure, README), greet with summary of findings, save to .kai/memory.md, ask what to build.
${status}${project_context}${progress}${memory}${dev_greeting}"

err_file=$(mktemp)
set +e
claude --session-id "$KAI_SESSION" $CLAUDE_ARGS --system-prompt "$SYSTEM_PROMPT" "${@:-Hey Kai}" 2>"$err_file"
exit_code=$?
set -e

if [ $exit_code -ne 0 ] && grep -qi "already in use" "$err_file" 2>/dev/null; then
    rm -f "$err_file"
    echo ""
    echo "Kai is already running in another terminal."
    echo ""
    echo "  1) Start a new session here:  kai --new"
    echo "  2) Continue in the other terminal where Kai is running"
    echo ""
    exit 1
fi
rm -f "$err_file"
