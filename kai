#!/bin/bash
# Kai — Your AI Shopify expert, product manager, and development team
# https://github.com/kraftapps-ai/kai
#
# Just run: kai

set -e

# ── Version ───────────────────────────────────────────

KAI_VERSION=$(node -p "require('$(dirname "$(readlink -f "$(which kai)" 2>/dev/null || echo "$0")")/package.json').version" 2>/dev/null || echo "unknown")

if [ "${1:-}" = "--version" ] || [ "${1:-}" = "-v" ]; then
    echo "kai v${KAI_VERSION}"
    exit 0
fi

# ── Parse kai flags ──────────────────────────────────

KAI_TMUX=true
PASSTHROUGH_ARGS=()
for arg in "$@"; do
    case "$arg" in
        --no-tmux) KAI_TMUX=false ;;
        --new) PASSTHROUGH_ARGS+=("$arg") ;;
        *) PASSTHROUGH_ARGS+=("$arg") ;;
    esac
done
set -- "${PASSTHROUGH_ARGS[@]}"

# Fall back if tmux is not installed
if ! command -v tmux &>/dev/null; then
    KAI_TMUX=false
fi

# ── tmux session management ──────────────────────────

KAI_TMUX_SESSION="kai"

if [ "$KAI_TMUX" = true ]; then
    # Already inside the kai tmux session — skip setup, run PM directly
    if [ -n "${TMUX:-}" ] && [ "$(tmux display-message -p '#S' 2>/dev/null)" = "$KAI_TMUX_SESSION" ]; then
        : # continue to normal execution below
    elif tmux has-session -t "$KAI_TMUX_SESSION" 2>/dev/null; then
        # Existing session — respawn PM in pane 0, reattach
        tmux respawn-pane -k -t "${KAI_TMUX_SESSION}:0.0" \
            "kai --no-tmux $(printf '%q ' "$@")"
        exec tmux attach-session -t "$KAI_TMUX_SESSION"
    else
        # New session: pane 0 = PM, pane 1 = dev loop (waiting)
        tmux new-session -d -s "$KAI_TMUX_SESSION" \
            "kai --no-tmux $(printf '%q ' "$@")"
        tmux split-window -h -d -t "${KAI_TMUX_SESSION}:0"
        exec tmux attach-session -t "$KAI_TMUX_SESSION"
    fi
fi

PRD_FILE=".kai/stories.json"
PROGRESS_FILE=".kai/progress.txt"
MEMORY_FILE=".kai/memory.md"
LOOP_SCRIPT=".kai/loop.sh"


# ── Ensure .kai/ and Playwright artifacts are git-ignored ─

mkdir -p .kai

# Add to project .gitignore (not just .kai/.gitignore) to prevent tracking
if [ -f ".gitignore" ]; then
    for pattern in ".kai/" ".playwright-mcp/"; do
        grep -qxF "$pattern" .gitignore 2>/dev/null || echo "$pattern" >> .gitignore
    done
else
    printf '%s\n' ".kai/" ".playwright-mcp/" > .gitignore
fi

# Untrack .kai/ files if they were committed before the gitignore existed
if git ls-files --cached .kai/ 2>/dev/null | grep -q .; then
    git rm -r --cached .kai/ > /dev/null 2>&1 || true
fi
if git ls-files --cached .playwright-mcp/ 2>/dev/null | grep -q .; then
    git rm -r --cached .playwright-mcp/ > /dev/null 2>&1 || true
fi

# ── Auto-init if needed ───────────────────────────────

# Migrate old file locations (pre-1.5.0)
if [ -f "kai.json" ] && [ ! -f "$PRD_FILE" ]; then
    mkdir -p .kai
    mv kai.json "$PRD_FILE"
    echo "  Migrated kai.json → $PRD_FILE"
fi
if [ -f "kai-progress.txt" ] && [ ! -f "$PROGRESS_FILE" ]; then
    mkdir -p .kai
    mv kai-progress.txt "$PROGRESS_FILE"
    echo "  Migrated kai-progress.txt → $PROGRESS_FILE"
fi

if [ ! -f "$PRD_FILE" ]; then
    mkdir -p .kai

    cat > "$PRD_FILE" << 'EOF'
{
  "branchName": "main",
  "userStories": []
}
EOF

    echo "# Kai Progress Log" > "$PROGRESS_FILE"
fi

# Init memory file if it doesn't exist
if [ ! -f "$MEMORY_FILE" ]; then
    mkdir -p .kai
    cat > "$MEMORY_FILE" << 'EOF'
# Kai Memory

This file is automatically maintained by Kai to preserve context between sessions.
Do not edit manually unless you want to correct or add context for Kai.

## Current Focus
<!-- What we're currently working on -->

## Key Decisions
<!-- Important decisions made during our conversations -->

## Open Questions / Blockers
<!-- Things that need to be resolved -->

## Session Log
<!-- Brief log of what happened in each session -->
EOF
fi

# ── Ensure MCP servers are available ─────────────────

# Track what's already configured
playwright_available=false
shopify_dev_available=false
mantle_available=false

for config in \
    ".mcp.json" \
    ".claude/settings.local.json" \
    "$HOME/.claude/settings.local.json" \
    "$HOME/.claude/settings.json"; do
    if [ -f "$config" ]; then
        grep -q "playwright" "$config" 2>/dev/null && playwright_available=true
        grep -q "shopify-dev" "$config" 2>/dev/null && shopify_dev_available=true
        grep -q "mantle" "$config" 2>/dev/null && mantle_available=true
    fi
done

# Check Claude Code plugins for Playwright
if [ "$playwright_available" = false ]; then
    for plugin_dir in "$HOME/.claude/plugins"/*/external_plugins/playwright/; do
        if [ -f "${plugin_dir}.mcp.json" ]; then
            playwright_available=true
            break
        fi
    done
fi

# Build MCP config with all needed servers
needs_mcp_update=false
if [ "$playwright_available" = false ] || [ "$shopify_dev_available" = false ] || [ "$mantle_available" = false ]; then
    needs_mcp_update=true
fi

if [ "$needs_mcp_update" = true ]; then
    if [ -f ".mcp.json" ]; then
        # Merge with existing config
        mcp_config=$(cat .mcp.json)

        if [ "$playwright_available" = false ] && ! echo "$mcp_config" | grep -q "playwright"; then
            echo "Setting up Playwright browser testing..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers.playwright = {"command": "npx", "args": ["@playwright/mcp@latest"]}')
        fi

        if [ "$shopify_dev_available" = false ] && ! echo "$mcp_config" | grep -q "shopify-dev"; then
            echo "Setting up Shopify Dev MCP (docs, GraphQL schemas, Liquid validation)..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["shopify-dev-mcp"] = {"command": "npx", "args": ["-y", "@shopify/dev-mcp@latest"]}')
        fi

        if [ "$mantle_available" = false ] && ! echo "$mcp_config" | grep -q "mantle"; then
            echo "Setting up Mantle MCP (billing, subscriptions, analytics)..."
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["mantle-foundations"] = {"type": "http", "url": "https://mcp.heymantle.com/foundations"}')
            mcp_config=$(echo "$mcp_config" | jq '.mcpServers["mantle-core"] = {"type": "http", "url": "https://mcp.heymantle.com/core"}')
        fi

        echo "$mcp_config" > .mcp.json
    else
        echo "Setting up MCP servers..."
        echo "  - Playwright (browser testing)"
        echo "  - Shopify Dev MCP (docs, GraphQL schemas, Liquid validation)"
        echo "  - Mantle MCP (billing, subscriptions, analytics)"

        cat > .mcp.json << 'MCPEOF'
{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "shopify-dev-mcp": {
      "command": "npx",
      "args": ["-y", "@shopify/dev-mcp@latest"]
    },
    "mantle-foundations": {
      "type": "http",
      "url": "https://mcp.heymantle.com/foundations"
    },
    "mantle-core": {
      "type": "http",
      "url": "https://mcp.heymantle.com/core"
    }
  }
}
MCPEOF
    fi
    echo "  MCP servers configured in .mcp.json"
fi

# ── Create loop MCP config (no Playwright) ───────────

# Worker/reviewer don't need Playwright — it spawns Chromium and causes freezes
if [ -f ".mcp.json" ]; then
    jq 'del(.mcpServers.playwright)' .mcp.json > .kai/loop-mcp.json
else
    echo '{"mcpServers":{}}' > .kai/loop-mcp.json
fi

# ── Create the implementation loop script ─────────────

cat > "$LOOP_SCRIPT" << 'LOOPEOF'
#!/bin/bash
# Kai implementation loop — called by the PM when stories are ready
set -e

PRD_FILE=".kai/stories.json"
PROGRESS_FILE=".kai/progress.txt"
LOOP_MCP_ARGS="--mcp-config .kai/loop-mcp.json"

# Cap Node.js memory to prevent test runners from consuming all RAM
export NODE_OPTIONS="--max-old-space-size=2048"

WORKER_PROMPT='You are an autonomous AI developer specializing in Shopify app and theme development.

## Your Shopify expertise

You are an expert Shopify developer. You have access to the Shopify Dev MCP tools — USE THEM:
- **learn_shopify_api** — ALWAYS call this first to initialize API context before any Shopify work
- **search_docs_chunks** — Search shopify.dev docs for implementation guidance
- **fetch_full_docs** — Get complete documentation pages when you need deep detail
- **introspect_graphql_schema** — Explore Admin API, Storefront API, and other GraphQL schemas. Use this to find the right queries, mutations, types, and fields
- **validate_graphql_codeblocks** — Validate your GraphQL operations against the schema BEFORE committing
- **validate_component_codeblocks** — Validate Shopify component code
- **validate_theme_codeblocks** — Validate Liquid template files
- **validate_theme** — Run full theme validation with Theme Check

### Mandatory workflow for Shopify code
1. Before writing any Shopify API code, call `learn_shopify_api` to initialize context
2. Use `introspect_graphql_schema` to find the exact types, fields, and mutations you need
3. Use `search_docs_chunks` or `fetch_full_docs` when you need implementation patterns or best practices
4. After writing GraphQL operations, call `validate_graphql_codeblocks` to verify them
5. After writing Liquid code, call `validate_theme_codeblocks` or `validate_theme` to verify it
6. NEVER guess at API fields, mutation inputs, or Liquid filters — always introspect or search first

## Your inputs
- `@.kai/stories.json` — user stories with `passes: true/false`.
- `@.kai/progress.txt` — log of what has been done.

## Your task (ONE story per loop) — TDD workflow

1. Read .kai/stories.json, find the highest-priority story where `passes: false`.
2. Read .kai/progress.txt for context on previous work.
3. **PLAN before coding.** List files and changes before touching code.
4. If the story involves Shopify APIs, call `learn_shopify_api` then use `introspect_graphql_schema` and `search_docs_chunks` to understand the right approach.
5. **WRITE FAILING TESTS FIRST.** For each acceptance criterion, write a test that verifies it. Run ONLY the relevant test file(s) — they MUST fail (red). If a test already passes, your test is not testing the right thing.
6. **Implement ONLY enough code to make the tests pass (green).** No more, no less. Run only the relevant test file(s) to verify.
7. **Refactor** if needed — clean up while keeping tests green.
8. **Final validation ONCE:** Run the full test suite ONE TIME at the end. Also validate GraphQL with `validate_graphql_codeblocks`, validate Liquid with `validate_theme_codeblocks`.
9. **SELF-REVIEW.** For each acceptance criterion, cite the test that covers it AND evidence it passes (file, line, command output). No "should work" or "probably".

## IMPORTANT: Resource management
- **NEVER run the full test suite repeatedly.** Run targeted tests during development (e.g., `npx vitest run path/to/test.ts`). Only run the full suite ONCE as a final check before committing.
- **Always use `npx vitest run`** (not `npx vitest` without `run`) — watch mode will hang forever.
10. Commit with a descriptive message.
11. Update .kai/stories.json: set `passes` to `true`.
12. Append to .kai/progress.txt.

## Rules
- ONE STORY PER LOOP.
- **NEVER switch branches.** Always commit to the current branch. Do NOT run `git checkout`, `git switch`, or `git branch`. The PM manages branches — you just commit your work.
- **TDD is mandatory.** Tests first, then implementation. No exceptions.
- No placeholders. Fully implement or report BLOCKED.
- Do not break existing functionality. Run the full test suite ONCE at the end as a final check.
- ALWAYS validate GraphQL and Liquid code using the MCP tools before marking complete.
- If ALL stories have `passes: true`, output: <promise>COMPLETE</promise>

## Rationalization Blockers
| Thought | Reality | Action |
|---|---|---|
| "Already implemented" | You have not verified. | Read code, run build. |
| "Just mark complete" | No code changes = not done. | Implement it. |
| "Build passes = works" | Build ≠ correct. | Check each criterion. |
| "Close enough" | Partial = broken. | All criteria or BLOCKED. |
| "Skip review" | Simple code has bugs. | Always self-review. |
| "I know the API" | APIs change. Schema is truth. | Introspect first. |
| "Tests can come later" | TDD means tests FIRST. | Write failing test before any code. |
| "This is hard to test" | Find a way or report BLOCKED. | Never skip tests. |'

context_files="@${PRD_FILE} @${PROGRESS_FILE}"
if [ -f ".kai/context.txt" ]; then
    while IFS= read -r file; do
        [ -n "$file" ] && [ -f "$file" ] && context_files="$context_files @${file}"
    done < .kai/context.txt
fi

iteration=0
review_failures=0

# Kill orphaned child processes (vitest, esbuild, etc.) between iterations
cleanup_orphans() {
    for proc in vitest esbuild playwright; do
        pkill -f "$proc" 2>/dev/null || true
    done
}
trap cleanup_orphans EXIT

while :; do
    iteration=$((iteration + 1))
    REMAINING=$(jq '[.userStories[] | select(.passes == false)] | length' "$PRD_FILE")

    if [ "$REMAINING" -eq 0 ]; then
        echo "All stories complete!"
        break
    fi

    NEXT_ID=$(jq -r '[.userStories[] | select(.passes == false)] | sort_by(.priority) | .[0].id' "$PRD_FILE")
    NEXT=$(jq -r '[.userStories[] | select(.passes == false)] | sort_by(.priority) | .[0].title' "$PRD_FILE")

    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "#${iteration} — $(date)"
    echo "  Remaining: $REMAINING | Next: $NEXT"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    start_time=$(date +%s)

    # jq filter for streaming claude output — shows tool calls, text, and results
    STREAM_FILTER='
if .type == "assistant" then
    ([.message.content[] |
        if .type == "tool_use" then "⚡ " + .name + ": " + (.input.command // .input.file_path // .input.pattern // "" | tostring | .[0:150])
        elif .type == "text" then .text
        else empty end
    ] | join("\n"))
elif .type == "user" and .tool_use_result then
    "  → " + (.tool_use_result.stdout // "" | .[0:200] | gsub("\n"; " "))
elif .type == "result" then
    "✅ Done (" + (.duration_ms / 1000 | tostring | .[0:5]) + "s, $" + (.total_cost_usd | tostring | .[0:6]) + ")"
else empty end'

    # Stream worker output live
    set +e
    claude -p --output-format stream-json --verbose --dangerously-skip-permissions $LOOP_MCP_ARGS \
        --system-prompt "$WORKER_PROMPT" $context_files 2>&1 | \
        tee .kai/worker-stream.tmp | \
        jq --unbuffered -r "$STREAM_FILTER" 2>/dev/null
    exit_code=${PIPESTATUS[0]}
    result=$(jq -r 'select(.type == "result") | .result // empty' .kai/worker-stream.tmp 2>/dev/null)
    set -e

    elapsed=$(( $(date +%s) - start_time ))

    if [ $exit_code -ne 0 ]; then
        echo "  Worker failed (code ${exit_code}). Restarting..."
        continue
    fi

    if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
        echo "All stories complete after $iteration iterations!"
        exit 0
    fi

    # Review
    STORY_PASSES=$(jq -r --arg id "$NEXT_ID" '.userStories[] | select(.id == $id) | .passes' "$PRD_FILE")
    if [ "$STORY_PASSES" = "true" ]; then
        echo ""
        echo "  📋 Reviewing story #${NEXT_ID}..."
        last_commit=$(git log --oneline -1 2>/dev/null || echo "no git")
        ACCEPTANCE=$(jq -r --arg id "$NEXT_ID" '.userStories[] | select(.id == $id) | .acceptanceCriteria | join("\n- ")' "$PRD_FILE")

        REVIEW_PROMPT="You are a Shopify expert code reviewer. Story #${NEXT_ID} ('${NEXT}') claims complete.
Last commit: ${last_commit}
Acceptance criteria:
- ${ACCEPTANCE}
Read git diff HEAD~1 HEAD. Verify EACH criterion. Be skeptical.
If the story involves Shopify APIs, use introspect_graphql_schema to verify the code uses correct fields and types.
If it involves Liquid, use validate_theme_codeblocks to check for errors.
If ANY fails: REVIEW_FAIL: [reason]
If all pass: REVIEW_PASS"

        set +e
        claude -p --output-format stream-json --verbose --dangerously-skip-permissions $LOOP_MCP_ARGS \
            "$REVIEW_PROMPT" 2>&1 | \
            tee .kai/review-stream.tmp | \
            jq --unbuffered -r "$STREAM_FILTER" 2>/dev/null
        review=$(jq -r 'select(.type == "result") | .result // empty' .kai/review-stream.tmp 2>/dev/null)
        set -e

        if [[ "$review" == *"REVIEW_FAIL"* ]]; then
            jq --arg id "$NEXT_ID" '(.userStories[] | select(.id == $id)).passes = false' "$PRD_FILE" > "${PRD_FILE}.tmp" && mv "${PRD_FILE}.tmp" "$PRD_FILE"
            echo "REVIEW FEEDBACK: $review" >> "$PROGRESS_FILE"
            review_failures=$((review_failures + 1))
            if [ $review_failures -ge 3 ]; then
                echo ""
                echo "╔══════════════════════════════════════════════════╗"
                echo "║  STALLED: Story #${NEXT_ID} failed review 3 times  ║"
                echo "╚══════════════════════════════════════════════════╝"
                echo ""
                echo "Review feedback:" >> "$PROGRESS_FILE"
                echo "$review" >> "$PROGRESS_FILE"
                echo "" >> "$PROGRESS_FILE"
                echo "STALLED: Story #${NEXT_ID} failed review 3 times. Human intervention needed." >> "$PROGRESS_FILE"
                echo "Loop stopped at $(date). Waiting for human intervention."
                exit 1
            fi
        else
            review_failures=0
        fi
    fi

    echo "Done in $((elapsed / 60))m $((elapsed % 60))s"
    cleanup_orphans
    echo ""
done
LOOPEOF
chmod +x "$LOOP_SCRIPT"

# ── Build status summary ──────────────────────────────

status=""
if [ -f "$PRD_FILE" ]; then
    total=$(jq '.userStories | length' "$PRD_FILE")
    done_count=$(jq '[.userStories[] | select(.passes == true)] | length' "$PRD_FILE")
    remaining=$((total - done_count))
    if [ "$total" -gt 0 ]; then
        status="

Current progress: ${done_count}/${total} stories complete (${remaining} remaining).
$(jq -r '.userStories[] | "- [\(if .passes then "DONE" else "TODO" end)] #\(.id): \(.title)"' "$PRD_FILE")"
    fi
fi

progress=""
if [ -f "$PROGRESS_FILE" ] && [ "$(wc -l < "$PROGRESS_FILE")" -gt 2 ]; then
    progress="

Recent progress (.kai/progress.txt):
$(tail -15 "$PROGRESS_FILE")"
fi

# Only inject memory if it has real content (not just the default template)
memory=""
if [ -f "$MEMORY_FILE" ]; then
    stripped_mem=$(sed 's/<!--.*-->//g' "$MEMORY_FILE" | sed '/^$/N;/^\n$/d')
    if echo "$stripped_mem" | grep -qvE '^(#|$)'; then
        memory="

## Kai Memory (from previous sessions)
$(cat "$MEMORY_FILE")"
    fi
fi

dev_name=$(git config user.name 2>/dev/null || echo "")
dev_greeting=""
[ -n "$dev_name" ] && dev_greeting="
The developer's name is: ${dev_name}"

# ── Build loop run instructions for PM ────────────────

LOOP_MONITOR="After starting the loop, IMMEDIATELY run \`/loop 5m\` with a prompt that reads .kai/stories.json and .kai/progress.txt to check progress, then report a brief status update to the developer (e.g., \"Story #X complete, working on #Y, 3 remaining\"). Stop the /loop when all stories are done or the loop has stopped."

if [ "$KAI_TMUX" = true ] || [ -n "${TMUX:-}" ]; then
    LOOP_INSTRUCTIONS="To run implementation, execute: \`tmux send-keys -t ${KAI_TMUX_SESSION}:0.1 '.kai/loop.sh 2>&1 | tee .kai/loop.log' Enter\`
The dev loop output streams live in the right tmux pane. You can also check \`tail -f .kai/loop.log\`.
To stop the loop: \`tmux send-keys -t ${KAI_TMUX_SESSION}:0.1 C-c\`
${LOOP_MONITOR}"
else
    LOOP_INSTRUCTIONS="To run implementation, execute: \`nohup .kai/loop.sh > .kai/loop.log 2>&1 &\` then monitor with \`tail -f .kai/loop.log\`
${LOOP_MONITOR}"
fi

# ── Build Claude args ─────────────────────────────────

CLAUDE_ARGS="--dangerously-skip-permissions --name kai"

# ── Launch the PM ─────────────────────────────────────

SYSTEM_PROMPT="You are Kai — an AI product manager, tech lead, and **Shopify expert**. You work directly with the developer to plan and ship Shopify apps, themes, and integrations.

## Session persistence

You maintain a memory file at \`.kai/memory.md\` that preserves context between sessions. This is critical — it's how you remember what happened in previous conversations.

### Reading memory
- **All context is already loaded in this system prompt** — story status, progress log, and memory are all below. Do NOT read files on startup.
- Use the loaded memory to greet the developer with instant awareness of where you left off
- If memory has content, reference it naturally: \"Hey {name} — picking up where we left off on X\"

### Writing memory
You MUST update \`.kai/memory.md\` in these situations:
- **After creating or modifying stories** — record what was planned and why
- **After the dev loop completes** — record what was built and any issues
- **When the developer makes a key decision** — record the decision and reasoning
- **When there are open questions or blockers** — record them so you remember next time
- **Before the developer leaves** — if they say \"bye\", \"done for today\", \"gotta go\", etc., immediately update memory with a session summary

### Memory format
Keep \`.kai/memory.md\` organized with these sections:
- **Current Focus** — what we're actively working on
- **Key Decisions** — important choices and their reasoning
- **Open Questions / Blockers** — unresolved issues
- **Session Log** — brief dated entries of what happened (newest first, keep last 10)

Keep entries concise. Memory is context, not a novel.

## Your Shopify expertise

You are a deep expert in the Shopify ecosystem. You have access to powerful Shopify Dev MCP tools — USE THEM proactively:

### Shopify Dev MCP tools (always available)
- **learn_shopify_api** — Initialize API context. Call this at the start of any Shopify-related conversation.
- **search_docs_chunks** — Search all of shopify.dev for docs, guides, patterns, and examples
- **fetch_full_docs** — Get complete documentation pages by path
- **introspect_graphql_schema** — Explore any Shopify GraphQL API schema (Admin, Storefront, Customer Account, Functions, Partner API, Payment Apps, POS UI Extensions). Find types, queries, mutations, fields, and arguments.
- **validate_graphql_codeblocks** — Validate GraphQL operations against the real schema
- **validate_component_codeblocks** — Validate Shopify UI component code
- **validate_theme_codeblocks** — Validate individual Liquid files
- **validate_theme** — Run comprehensive theme validation (Theme Check)

### When to use these tools
- Developer asks about a Shopify API → \`introspect_graphql_schema\` + \`search_docs_chunks\`
- Planning stories that involve Shopify APIs → introspect the schema to understand what's possible
- Reviewing code that uses Shopify APIs → validate GraphQL operations
- Working with themes → validate Liquid code
- Unsure about best practices → search the docs
- **ALWAYS prefer introspecting the real schema over guessing at API shapes**

### Shopify Storefront MCP (per-store)
Every Shopify store exposes a Storefront MCP endpoint at \`https://{shop}.myshopify.com/api/mcp\`. This provides:
- **search_shop_catalog** — Search the store's products, prices, variants
- **search_shop_policies_and_faqs** — Query store policies, shipping, returns
- **get_cart** / **update_cart** — Manage shopping carts

If the developer's store domain is in memory, you can point them to this endpoint for storefront integrations.

### Mantle MCP (billing & analytics)
You have access to Mantle MCP servers for Shopify app billing and analytics:

- **mantle-foundations** — Code generation for Mantle integration: billing UI, customer identification, usage event tracking, feature gating, plan/feature/entitlement configuration. Use this when implementing or modifying billing, subscriptions, or paywalls.
- **mantle-core** — Customer analytics, subscription details, revenue metrics (50+ metrics including churn, retention, MRR), sales CRM, transaction history. Use this to look up customer data, analyze revenue, or check subscription status.

OAuth authentication happens automatically via browser on first use — no API keys needed.

### Your Shopify knowledge includes
- **App development**: Remix apps, App Bridge, session tokens, OAuth, webhooks, GDPR compliance, app extensions
- **Admin API**: GraphQL (preferred) and REST, pagination, rate limits, bulk operations, metafields, metaobjects
- **Storefront API**: Headless commerce, customer accounts, cart API, checkout
- **Themes**: Liquid, JSON templates, sections, blocks, Theme Check, Dawn reference theme
- **Shopify CLI**: \`shopify app dev\`, \`shopify theme dev\`, \`shopify app deploy\`, extensions
